# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID пользователей с доступом (через запятую)
WHITELIST_USER_IDS=123456789,987654321

# Путь к мастер-файлу Excel
EXCEL_FILE_PATH=C:\Path\To\LKW_Fahrer_Data.xlsm
# Опционально: путь к .xlsb (если не указан, берется соседний LKW_Fahrer_Plan.xlsb)
XLSB_FILE_PATH=

# PostgreSQL connection string (Neon)
# Пример: postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Путь для временной копии Excel (рекомендуется %TEMP%)
EXCEL_BOT_COPY=%TEMP%\LKW_Fahrer_Data_BOT.xlsm

# HTTPS URL мини-приложения Telegram (WebApp) для кнопки "Открыть окно"
# Например: https://your-domain.example.com/lkw_report_bot/
# Для production используйте постоянный домен (не trycloudflare)
WEBAPP_URL=https://example.com/lkw_report_bot/
HEARTBEAT_INTERVAL_SEC=30
# Mini App only mode: set true only if local web_server.py is used.
WATCHDOG_REQUIRE_HTTP=false

# ID администратора для уведомлений об ошибках
ADMIN_CHAT_ID=745125435

# LKW HU/SP/57B deadline notifications
# Sends on the 15th day of the month before the due month, e.g. 10/2026 -> 15/09/2026.
LKW_DEADLINE_NOTIFY_CHAT_ID=6863783942
LKW_DEADLINE_NOTIFY_EMAIL=a.reh@groo.de
LKW_DEADLINE_TIMEZONE=Europe/Berlin
LKW_DEADLINE_STATE_FILE=%TEMP%\lkw_deadline_notify_state.json

# SMTP for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Scheduler (автоматическая отправка отчёта)
SCHEDULE_ENABLED=true
SCHEDULE_CRON=0 10 * * 1
SCHEDULE_REPORT_TYPE=bericht
SCHEDULE_TIMEZONE=Europe/Berlin
# Опционально: отдельный список получателей расписания.
# Если пусто, используется WHITELIST_USER_IDS.
SCHEDULE_USER_IDS=123456789,987654321

# ETL freshness monitor
# Если последний успешный импорт старше этого порога, отправляется alert администратору.
ETL_STALE_AFTER_HOURS=4
# Optional: override threshold in seconds (for testing). If set, takes precedence.
ETL_STALE_AFTER_SECONDS=
# Опционально: путь к state-файлу анти-спама уведомлений.
ETL_STALE_STATE_FILE=%TEMP%\lkw_etl_stale_state.json

# Manual ETL trigger for Mini App
# Local web_server.py should expose POST /api/etl/run and validate this token.
ETL_TRIGGER_TOKEN=replace_with_long_random_token
# Cloudflare Worker / Mini App runtime should call the public endpoint below.
# Example: https://your-local-server-or-tunnel.example.com/api/etl/run
ETL_TRIGGER_URL=

# ETL source watcher (run via install_etl_watch_schedule.cmd)
# If true, watcher can trigger ETL shortly after Excel source files are updated.
ETL_WATCH_ENABLED=true
# Wait time after last detected file change before ETL starts.
ETL_WATCH_SETTLE_SECONDS=90
# Minimal pause between auto-triggers.
ETL_WATCH_MIN_INTERVAL_SECONDS=600
# State file for source watcher.
ETL_WATCH_STATE_FILE=%TEMP%\lkw_etl_watch_state.json

# Worker auth cache (Cloudflare)
ALLOWED_USERS_CACHE_SEC=300

NODE_ENV=development

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change_me_in_real_env
SESSION_COOKIE_NAME=lkw_planning_session
SESSION_COOKIE_SECURE=false

# Database
# Use a separate database or a dedicated schema for the planning app.
DATABASE_URL=postgresql://planning_user:planning_password@postgres:5432/lkw_planning?schema=planning
DIRECT_URL=postgresql://planning_user:planning_password@postgres:5432/lkw_planning?schema=planning
SHADOW_DATABASE_URL=postgresql://planning_user:planning_password@postgres:5432/lkw_planning_shadow?schema=planning
SHADOW_DIRECT_URL=postgresql://planning_user:planning_password@postgres:5432/lkw_planning_shadow?schema=planning
REPORTING_DATABASE_URL=postgresql://readonly_reporting_user:readonly_password@reporting-host:5432/reporting_db

# Local Docker Postgres
POSTGRES_DB=lkw_planning
POSTGRES_USER=planning_user
POSTGRES_PASSWORD=planning_password

# Excel import paths for local/dev only.
DAILY_PLAN_WORKBOOK_PATH=C:\Path\To\Dispo 2026 Wochenplanung_.xlsm
EXCEL_LKW_DATA_PATH=
EXCEL_PLAN_PATH=
IMPORT_STAGING_DIR=./storage/imports
EXPORT_OUTPUT_DIR=./storage/exports

# Backups
BACKUP_DIR=./storage/backups
BACKUP_RETENTION_DAYS=30
OFFSITE_BACKUP_ENABLED=false
B2_REMOTE_NAME=backblaze_b2
B2_BUCKET=
B2_PREFIX=daily
B2_KEY_ID=
B2_APPLICATION_KEY=

# Initial local seed only. Change before production.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_minimum_12_chars
ADMIN_DISPLAY_NAME=Admin

# Future integrations. Keep empty in MVP.
TELEGRAM_INTEGRATION_ENABLED=false
TELEGRAM_BOT_TOKEN=
ACCOUNTING_INTEGRATION_ENABLED=false
